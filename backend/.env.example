# Copiá este archivo como .env y completá los valores
# cp .env.example .env

# MongoDB Atlas
# cloud.mongodb.com → Database Access → tu usuario
MONGO_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=<appName>
MONGO_DB=linkpro

# PostgreSQL / Supabase
# supabase.com → Project Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# Supabase API
# supabase.com → Project Settings → API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_KEY=<service-role-key>

# Neo4j
# console.neo4j.io → tu instancia → Connect
NEO4J_URI=neo4j+ssc://<instance-id>.databases.neo4j.io
NEO4J_USER=<usuario>
NEO4J_PASSWORD=<password>

# AstraDB (Datastax)
# astra.datastax.com → Organization Settings → Tokens
ASTRA_TOKEN=AstraCS:<token>
ASTRA_ENDPOINT=https://<db-id>-<region>.apps.astra.datastax.com

# Flask
FLASK_ENV=development
FRONTEND_URL=http://localhost:5173

# Email (para recuperación de contraseña)
# Opción A: Gmail App Password → myaccount.google.com/apppasswords
# Opción B: Mailtrap → mailtrap.io → SMTP Settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASS=tu_app_password
SMTP_FROM=tu_email@gmail.com
